{
    "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "src/**/*.ts",
            "src/**/*.tsx",
            "!src/components/vortex.tsx",
            "!**/.next",
            "!**/dist",
            "!**/build",
            "!**/coverage",
            "!**/.turbo",
            "!**/.vercel"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "tab",
        "lineEnding": "lf",
        "lineWidth": 220
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "asNeeded",
            "trailingCommas": "none"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
